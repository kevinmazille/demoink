// English (United States) resources

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDI_DEMOHELPER          ICON                    "DemoHelper.ico"


/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDC_DEMOHELPER MENU
BEGIN
    POPUP "TrayContext"
    BEGIN
        MENUITEM "&Draw",                       ID_TRAYCONTEXT_DRAW
        MENUITEM SEPARATOR
        MENUITEM "&Options",                    ID_TRAYCONTEXT_OPTIONS
        MENUITEM "Start with &Windows",         ID_TRAYCONTEXT_AUTOSTART
        MENUITEM "&Help",                       IDHELP
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       IDM_EXIT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDR_DEMOHELPER ACCELERATORS
BEGIN
    "w",            ID_CMD_CLEARLINES,      ASCII,  NOINVERT
    "0",            ID_CMD_COLOR0,          ASCII,  NOINVERT
    "1",            ID_CMD_COLOR1,          ASCII,  NOINVERT
    "2",            ID_CMD_COLOR2,          ASCII,  NOINVERT
    "3",            ID_CMD_COLOR3,          ASCII,  NOINVERT
    "4",            ID_CMD_COLOR4,          ASCII,  NOINVERT
    "5",            ID_CMD_COLOR5,          ASCII,  NOINVERT
    "6",            ID_CMD_COLOR6,          ASCII,  NOINVERT
    "7",            ID_CMD_COLOR7,          ASCII,  NOINVERT
    "8",            ID_CMD_COLOR8,          ASCII,  NOINVERT
    "9",            ID_CMD_COLOR9,          ASCII,  NOINVERT
    VK_DOWN,        ID_CMD_DECREASE,        VIRTKEY, NOINVERT
    VK_UP,          ID_CMD_INCREASE,        VIRTKEY, NOINVERT
    "a",            ID_CMD_TEXTMODE,        ASCII,  NOINVERT
    "q",            ID_CMD_TOGGLETHEME,     ASCII,  NOINVERT
    "z",            ID_CMD_CYCLEBOARD,      ASCII,  NOINVERT
    VK_RIGHT,       ID_CMD_NEXTCOLOR,       VIRTKEY, NOINVERT
    VK_LEFT,        ID_CMD_PREVCOLOR,       VIRTKEY, NOINVERT
    VK_ESCAPE,      ID_CMD_QUITMODE,        VIRTKEY, NOINVERT
    "t",            ID_CMD_TOGGLEROP,       ASCII,  NOINVERT
    VK_BACK,        ID_CMD_UNDOLINE,        VIRTKEY, NOINVERT
    VK_F1,          IDHELP,                 VIRTKEY, NOINVERT
    "/",            IDM_ABOUT,              ASCII,  ALT, NOINVERT
    "?",            IDM_ABOUT,              ASCII,  ALT, NOINVERT
    VK_DELETE,      ID_CMD_REMOVEFIRST,     VIRTKEY, NOINVERT
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

// Options is a tabbed PropertySheet; each tab is a child property page below.

IDD_OPT_GENERAL DIALOGEX 0, 0, 235, 140
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | DS_CONTROL
CAPTION "General"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    ICON            IDI_DEMOHELPER,IDC_MYICON2,7,7,20,20
    CONTROL         "DemoInk, a fork of <a href=""https://tools.stefankueng.com/DemoHelper.html"">DemoHelper</a> by Stefan Kueng",IDC_SYSLINK1,
                    "SysLink",WS_TABSTOP,33,11,195,18
    GROUPBOX        "Display",IDC_STATIC,7,38,221,52
    LTEXT           "Capture only the monitor where the cursor is, or the whole virtual screen across all monitors.",IDC_STATIC,14,49,207,18
    CONTROL         "Current Monitor",IDC_CURRENTMONITOR,"Button",BS_AUTORADIOBUTTON,14,72,95,10
    CONTROL         "All Monitors",IDC_ALLMONITORS,"Button",BS_AUTORADIOBUTTON,119,72,95,10
END

IDD_OPT_DRAW DIALOGEX 0, 0, 235, 140
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | DS_CONTROL
CAPTION "Draw"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "After enabling drawing, change the pen size with Up/Down (or Ctrl+wheel) and cycle colors with Right/Left (or the wheel). Backspace erases the last stroke.",IDC_STATIC,7,7,221,26
    LTEXT           "Draw mode hotkey:",IDC_STATIC,7,43,68,8
    CONTROL         "",IDC_HOTKEY_DRAWMODE,"msctls_hotkey32",WS_BORDER | WS_TABSTOP,84,41,144,14
    LTEXT           "Remove lines after",IDC_STATIC,7,63,64,8
    EDITTEXT        IDC_FADESECONDS,84,60,40,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "seconds (0 = never)",IDC_STATIC,128,63,90,8
    GROUPBOX        "Defaults at launch",IDC_STATIC,7,82,221,51
    LTEXT           "Color (palette index 0-9):",IDC_STATIC,14,96,90,8
    EDITTEXT        IDC_DEFAULTCOLOR,119,93,40,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Pen width:",IDC_STATIC,14,115,90,8
    EDITTEXT        IDC_DEFAULTPENWIDTH,119,112,40,14,ES_AUTOHSCROLL | ES_NUMBER
END

IDD_OPT_TEXT DIALOGEX 0, 0, 235, 140
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | DS_CONTROL
CAPTION "Text"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Font and starting size used when typing text annotations (the mouse wheel still resizes text on the fly).",IDC_STATIC,7,7,221,18
    LTEXT           "Font:",IDC_STATIC,7,35,40,8
    COMBOBOX        IDC_TEXTFONT,84,33,144,80,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Default size:",IDC_STATIC,7,55,55,8
    EDITTEXT        IDC_TEXTSIZE,84,52,40,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "pixels",IDC_STATIC,128,55,40,8
END


